<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Log Energy Data"
            android:textColor="#FFD700"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Date Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_dark"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📅 Date"
                    android:textColor="#888888"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/tvLogDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvUpdateBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_yellow"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:text="NEW ENTRY"
                android:textColor="#FFD700"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="visible"/>
        </LinearLayout>

        <!-- Weather Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_dark"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☁️ Weather Condition"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/btnSunny"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="☀️ Sunny"
                    android:textColor="#000000"
                    android:backgroundTint="#FFD700"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnPartly"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="⛅ Partly"
                    android:textColor="#888888"
                    android:backgroundTint="#1A1A1A"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnCloudy"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="☁️ Cloudy"
                    android:textColor="#888888"
                    android:backgroundTint="#1A1A1A"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnRainy"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="🌧️ Rainy"
                    android:textColor="#888888"
                    android:backgroundTint="#1A1A1A"
                    android:textSize="12sp"
                    android:layout_marginStart="6dp"
                    android:stateListAnimator="@null"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Solar Generation Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_dark"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀️ Solar Generation"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/etGenerated"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:inputType="numberDecimal"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#444444"
                    android:hint="kWh Generated"
                    android:textSize="15sp"
                    android:layout_marginEnd="10dp"/>

                <Button
                    android:id="@+id/btnSimulate"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="🤖 Simulate"
                    android:textColor="#000000"
                    android:backgroundTint="#FFD700"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Consumption Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_dark"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠 Consumption"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etConsumed"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#444444"
                android:hint="kWh Consumed"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Settings Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_dark"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚙️ Settings"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grid Rate (₹/kWh)"
                        android:textColor="#666666"
                        android:textSize="11sp"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etPricePerUnit"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="numberDecimal"
                        android:textColor="#FFFFFF"
                        android:text="8.0"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Export Rate (₹/kWh)"
                        android:textColor="#666666"
                        android:textSize="11sp"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etExportRate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_background"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="numberDecimal"
                        android:textColor="#FFFFFF"
                        android:text="4.0"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Live Preview Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_dark_green"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estimated Savings"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvNetPreview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ 0.00"
                android:textColor="#00E676"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvNetKwh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Net: 0.0 kWh"
                android:textColor="#666666"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveLog"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💾  SAVE LOG"
            android:textColor="#000000"
            android:backgroundTint="#FFD700"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>